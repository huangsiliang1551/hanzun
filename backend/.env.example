APP_NAME=Hanzun CMS Backend
APP_DEBUG=false
APP_TIMEZONE=Asia/Shanghai
APP_URL=https://bagelsmachinery.com
APP_STORAGE_MODE=database

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=hanzun_cms
DB_USERNAME=hanzun_cms
DB_PASSWORD=CHANGE_ME_DATABASE_PASSWORD
DB_CHARSET=utf8mb4
DB_PREFIX=
DB_CONNECT_TIMEOUT=3

AUTH_ACCESS_TTL=7200
AUTH_REFRESH_TTL=2592000
AUTH_JWT_SECRET=CHANGE_ME_USE_64_RANDOM_HEX_CHARS
AUTH_LOGIN_MAX_ATTEMPTS=5

UPLOAD_DISK=local
UPLOAD_ROOT=public/uploads
UPLOAD_MAX_IMAGE_SIZE=5242880
UPLOAD_MAX_VIDEO_SIZE=52428800
UPLOAD_MAX_PDF_SIZE=20971520

DEEPSEEK_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DEEPSEEK_MODEL=qwen-plus
DEEPSEEK_API_KEY=
