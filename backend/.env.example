APP_NAME="Hanzun CMS"
APP_DEBUG=true
APP_TIMEZONE=Asia/Shanghai
APP_URL=http://127.0.0.1:8080

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=hanzun_cms
DB_USERNAME=root
DB_PASSWORD=
DB_CHARSET=utf8mb4
DB_PERSISTENT=false

AUTH_ACCESS_TTL=7200
AUTH_REFRESH_TTL=2592000
AUTH_LOGIN_MAX_ATTEMPTS=5
AUTH_LOGIN_WINDOW_SECONDS=900
AUTH_LOGIN_LOCK_SECONDS=900
AUTH_JWT_SECRET=change_me_to_a_random_64_char_secret
TRUSTED_PROXIES=127.0.0.1

UPLOAD_DISK=local
UPLOAD_ROOT=public/uploads
UPLOAD_MAX_IMAGE_MB=10
UPLOAD_MAX_VIDEO_MB=100
UPLOAD_MAX_FILE_MB=20
APP_ALLOW_RUNTIME_FALLBACK=false

MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME="Hanzun"

DEEPSEEK_BASE_URL=
DEEPSEEK_MODEL=
DEEPSEEK_API_KEY=
